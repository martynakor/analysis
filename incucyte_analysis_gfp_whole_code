#7. Helper functions

def load_incucyte(path):
    with open(path, "r", encoding="latin-1") as f:
        lines = f.readlines()
    hi = next(i for i, l in enumerate(lines) if l.startswith("Date Time"))
    df = pd.read_csv(path, sep="\t", decimal=",", skiprows=hi, encoding="latin-1")
    df["Date Time"] = pd.to_datetime(df["Date Time"], format="mixed", dayfirst=True)
    df.columns = df.columns.str.strip()
    return df.sort_values("Elapsed").reset_index(drop=True)

def get_sd(df, col):
    col_s = " ".join(col.strip().split())
    for c in df.columns:
        if " ".join(c.strip().split()) == col_s + " (Std Dev Img)":
            return df[c].values
    return np.zeros(len(df))

def build_col_map(source_conds, target_cols):
    target_data = [c for c in target_cols
                   if "Std Dev" not in c and c not in ["Date Time", "Elapsed"]]
    mapping = {}
    for rc in source_conds:
        if rc in target_data:
            mapping[rc] = rc; continue
        best, best_len = None, 0
        for cc in target_data:
            if (cc in rc or rc in cc) and len(cc) > best_len:
                best, best_len = cc, len(cc)
        if best:
            mapping[rc] = best; continue
        rc_words = set(rc.lower().split())
        best_len = 0
        for cc in target_data:
            overlap = len(rc_words & set(cc.lower().split()))
            if overlap > best_len:
                best, best_len = cc, overlap
        mapping[rc] = best if best else rc
    return mapping

def compute_density(source_df, conflu_df, col_map_fn, conds):
    density    = {}
    density_sd = {}
    for col in conds:
        r      = source_df[col].values
        c      = conflu_df[col_map_fn(col)].values
        c_safe = np.where(c == 0, np.nan, c)
        sd_r   = get_sd(source_df, col)
        sd_c   = get_sd(conflu_df, col_map_fn(col))
        rn     = r / c_safe
        sd_rn  = rn * np.sqrt((sd_r / np.where(r == 0, 1, r))**2 +
                               (sd_c / np.where(c == 0, 1, c))**2)
        density[col]    = rn
        density_sd[col] = sd_rn
    return density, density_sd

def compute_metrics(conds, conflu_df, col_map_fn, density, ctrl_density,
                    ctrl, time, slope_t_min, slope_t_max,
                    density_label="GFP delivery\nfold vs ctrl",
                    slope_label="GFP accum.\nslope (cnt/%/h)"):
    results = []
    for col in conds:
        y_conflu = conflu_df[col_map_fn(col)].values
        rn       = density[col]

        growth_index = y_conflu[-1] / y_conflu[0] if y_conflu[0] != 0 else np.nan

        ctrl_density_end = ctrl_density[-1] if ctrl_density[-1] != 0 else np.nan
        delivery_fold = rn[-1] / ctrl_density_end if ctrl_density_end else np.nan

        gfp_above_ctrl = rn - ctrl_density
        mask = (time >= slope_t_min) & (time <= slope_t_max)
        slope, _ = np.polyfit(time[mask], gfp_above_ctrl[mask], 1) if mask.sum() >= 2 \
                   else (np.nan, np.nan)

        results.append([
            col.strip(),
            f"{growth_index:.3f}",
            f"{delivery_fold:.2f}" if not np.isnan(delivery_fold) else "-",
            f"{slope:.4f}" if not np.isnan(slope) else "-"
        ])

    results_df = pd.DataFrame(results, columns=[
        "Condition",
        "Growth index",
        density_label,
        slope_label
    ])
    return results, results_df

def draw_table(ax, results_df):
    col_labels = results_df.columns.tolist()
    cell_data  = [list(row) for row in results_df.values.tolist()]
    n_rows = len(cell_data)
    n_cols = len(col_labels)

    WRAP_WIDTH = 22
    for i in range(n_rows):
        val = str(cell_data[i][0])
        if len(val) > WRAP_WIDTH:
            cell_data[i][0] = "\n".join(textwrap.wrap(val, WRAP_WIDTH))

    col_widths = []
    for j in range(n_cols):
        header_lines = str(col_labels[j]).split("\n")
        header_max   = max(len(l) for l in header_lines)
        data_max = 0
        for row in cell_data:
            for l in str(row[j]).split("\n"):
                data_max = max(data_max, len(l))
        col_widths.append(max(header_max, data_max))

    total = sum(col_widths)
    col_widths_norm = [w / total for w in col_widths]

    max_header_lines = max(len(str(c).split("\n")) for c in col_labels)
    max_data_lines   = max(
        max(len(str(row[j]).split("\n")) for j in range(n_cols))
        for row in cell_data
    )
    LINE_H  = FONT_SIZE_TABLE * 0.0013
    PADDING = 0.012

    header_height = LINE_H * max_header_lines + PADDING
    data_height   = LINE_H * max_data_lines   + PADDING
    header_height = max(header_height, 0.045)
    data_height   = max(data_height,   0.038)

    table = ax.table(cellText=cell_data, colLabels=col_labels,
                     cellLoc="center", loc="center",
                     colWidths=col_widths_norm,
                     bbox=[0, 0, 1, 1])
    table.auto_set_font_size(False)
    table.set_fontsize(FONT_SIZE_TABLE)

    for (row, col), cell in table.get_celld().items():
        if row == 0:
            cell.set_height(header_height)
        else:
            cell.set_height(data_height)

    for j in range(n_cols):
        cell = table[0, j]
        cell.set_facecolor("#f0f0f0")
        cell.set_text_props(fontweight="bold", color="black",
                            verticalalignment="center")
        cell.set_edgecolor("#aaaaaa")
        cell.set_linewidth(1.2)

    for i in range(1, n_rows + 1):
        bg = "#ffffff" if i % 2 == 1 else "#f9f9f9"
        for j in range(n_cols):
            cell = table[i, j]
            cell.set_facecolor(bg)
            cell.set_edgecolor("#cccccc")
            cell.set_linewidth(0.8)
            cell.set_text_props(color="black", verticalalignment="center")

    return table


