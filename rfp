conds = [c for c in rfp.columns
         if "Std Dev" not in c and c not in ["Date Time", "Elapsed"]]
conds = [c for c in conds if c.strip() not in CONDS_TO_REMOVE]

# Identify the control condition by matching the user-supplied name fragment
ctrl_matches = [c for c in conds if CTRL_NAME.lower() in c.lower()]
