if duplicates:
    print(f"\n!!! WARNING: duplicate mappings: {duplicates}")

# Convenience wrapper so panel-drawing code stays concise
def get_conflu(col):
    return col_map.get(col, col)

time = rfp["Elapsed"].values


#8. Colour palette
# Matplotlib default colour cycle extended with extra distinguishable colours.
# Markers are cycled independently so each condition has a unique colour+marker pair.

pub_palette = ["#1f77b4", "#e377c2", "#ff7f0e", "#9467bd",
               "#17becf", "#bcbd22", "#7f7f7f", "#8c564b"]
markers = ["o", "s", "D", "^", "v", "p", "*", "h"]


#9. Calculations

# --- RFP count density -------------------------------------------------------
# Normalise raw RFP object count by confluence to estimate signal per cell area.

rfp_density, rfp_density_sd = compute_density(rfp, conflu, get_conflu, conds)
ctrl_density = rfp_density[ctrl]

# Baseline values for control, used to compute AUC inhibition and KD fold
ctrl_conflu      = conflu[get_conflu(ctrl)].values
ctrl_conflu_auc  = np.trapezoid(ctrl_conflu, time)   # area under the control confluence curve
fold_ctrl_density = ctrl_density[-1] / ctrl_density[0]  # fold-change of ctrl density over time

# --- Per-condition summary metrics ------------------------------------------
results = []
for col in conds:
    y_conflu = conflu[get_conflu(col)].values
    rn       = rfp_density[col]

    # Growth index: ratio of final to initial confluence
    growth_index = y_conflu[-1] / y_conflu[0] if y_conflu[0] != 0 else np.nan

    # AUC inhibition: how much the confluence curve was suppressed vs. control
    # Positive values indicate reduced cell growth relative to control
    auc_inhibition = (ctrl_conflu_auc - np.trapezoid(y_conflu, time)) / ctrl_conflu_auc * 100

    # KD fold: percentage reduction in RFP density fold-change relative to control
    # Reflects how much the RFP signal accumulation was knocked down
    fold_cond = rn[-1] / rn[0]
    kd_fold   = (1 - fold_cond / fold_ctrl_density) * 100

    # KD slope: rate of knockdown deepening within the chosen time window
    # Computed as the slope of (ctrl_density - cond_density) / ctrl_density vs. time
    kd_series    = (ctrl_density - rn) / ctrl_density * 100
    mask         = (time >= SLOPE_T_MIN) & (time <= SLOPE_T_MAX)
    slope, _     = np.polyfit(time[mask], kd_series[mask], 1) if mask.sum() >= 2 \
                   else (np.nan, np.nan)

    results.append([
        col.strip(),
        f"{growth_index:.3f}",
        f"{auc_inhibition:.2f}",
        f"{kd_fold:.1f}",
        f"{slope:.3f}" if not np.isnan(slope) else "-"
    ])

results_df = pd.DataFrame(results, columns=[
    "Condition",
    "Growth index",
    "AUC inhib.\nconf. (%)",
    "KD fold\n(%)",
    "KD slope\n(%/h)"
])


