#6. Helper functions

def load_incucyte(path):
    """
    Parse an Incucyte export TSV file.
    The file header starts at the line beginning with 'Date Time'; everything
    above it (instrument metadata) is skipped. Decimal separator is a comma.
    latin-1 encoding handles special characters that appear in some exports.
    Returns a DataFrame sorted by the 'Elapsed' (hours) column.
    """
    with open(path, "r", encoding="latin-1") as f:
        lines = f.readlines()
    # Find the row index where the actual data header begins
    hi = next(i for i, l in enumerate(lines) if l.startswith("Date Time"))
    df = pd.read_csv(path, sep="\t", decimal=",", skiprows=hi, encoding="latin-1")
    df["Date Time"] = pd.to_datetime(df["Date Time"], format="mixed", dayfirst=True)
    df.columns = df.columns.str.strip()
    return df.sort_values("Elapsed").reset_index(drop=True)

def get_sd(df, col):
    """
    Return the Std Dev Img column that corresponds to `col`.
    Incucyte exports place standard deviation in a column named
    '<original_column_name> (Std Dev Img)'. If no matching column exists,
    a zero array is returned so errorbar() calls remain valid.
    """
    col_s = " ".join(col.strip().split())
    for c in df.columns:
        if " ".join(c.strip().split()) == col_s + " (Std Dev Img)":
            return df[c].values
    return np.zeros(len(df))

def build_col_map(source_conds, target_cols):
    """
    Build a dict mapping each condition name in `source_conds` to the best-matching
    column name in `target_cols`.

    Matching priority:
      1. Exact match
      2. One name is a substring of the other (longest match wins)
      3. Highest word-overlap between the two names (case-insensitive)

    This is necessary because Incucyte sometimes exports slightly different column
    names across files for the same experimental condition.
    """
    target_data = [c for c in target_cols
                   if "Std Dev" not in c and c not in ["Date Time", "Elapsed"]]
    mapping = {}
    for rc in source_conds:
        # Priority 1: exact match
        if rc in target_data:
            mapping[rc] = rc; continue
        # Priority 2: substring match — prefer the longer common string
        best, best_len = None, 0
        for cc in target_data:
            if (cc in rc or rc in cc) and len(cc) > best_len:
                best, best_len = cc, len(cc)
        if best:
            mapping[rc] = best; continue
        # Priority 3: maximum word overlap
        rc_words = set(rc.lower().split())
        best_len = 0
        for cc in target_data:
            overlap = len(rc_words & set(cc.lower().split()))
            if overlap > best_len:
                best, best_len = cc, overlap
        mapping[rc] = best if best else rc
    return mapping

def compute_density(source_df, conflu_df, col_map_fn, conds):
    """
    Normalise signal values by confluence to get a per-cell density estimate.

    density      = signal / confluence
    density_sd   = density × sqrt( (sd_signal/signal)² + (sd_confluence/confluence)² )
                   (error propagation for a ratio)

    Returns two dicts keyed by condition name: density values and their SDs.
    Confluence values of zero are replaced with NaN to avoid division errors.
    """
    density    = {}
    density_sd = {}
    for col in conds:
        r      = source_df[col].values
        c      = conflu_df[col_map_fn(col)].values
        c_safe = np.where(c == 0, np.nan, c)   # avoid division by zero
        sd_r   = get_sd(source_df, col)
        sd_c   = get_sd(conflu_df, col_map_fn(col))
        rn     = r / c_safe
        # Propagated error for rn = r/c
        sd_rn  = rn * np.sqrt((sd_r / np.where(r == 0, 1, r))**2 +
                               (sd_c / np.where(c == 0, 1, c))**2)
        density[col]    = rn
        density_sd[col] = sd_rn
    return density, density_sd

def draw_table(ax, results_df):
    """
    Render a formatted summary table on the given Axes object.

    Features:
    - Column widths are proportional to the longest content in each column
    - Long condition names are word-wrapped to WRAP_WIDTH characters
    - Header row has a light grey background with bold text
    - Data rows alternate between white and near-white for readability
    - Row heights are calculated from font size to avoid clipping multi-line text
    """
    import textwrap
    col_labels = results_df.columns.tolist()
    cell_data  = [list(row) for row in results_df.values.tolist()]
    n_rows = len(cell_data)
    n_cols = len(col_labels)

    # Wrap long condition names (first column) so they don't overflow the cell
    WRAP_WIDTH = 22
    for i in range(n_rows):
        val = str(cell_data[i][0])
        if len(val) > WRAP_WIDTH:
            cell_data[i][0] = "\n".join(textwrap.wrap(val, WRAP_WIDTH))

    # Determine column widths based on the widest content (header or data)
    col_widths = []
    for j in range(n_cols):
        header_lines = str(col_labels[j]).split("\n")
        header_max   = max(len(l) for l in header_lines)
        data_max = 0
        for row in cell_data:
            for l in str(row[j]).split("\n"):
                data_max = max(data_max, len(l))
        col_widths.append(max(header_max, data_max))

    # Normalise widths to [0, 1] so they sum to 1.0 for the table bbox
    total = sum(col_widths)
    col_widths_norm = [w / total for w in col_widths]

    # Compute row heights to accommodate the tallest cell content
    max_header_lines = max(len(str(c).split("\n")) for c in col_labels)
    max_data_lines   = max(
        max(len(str(row[j]).split("\n")) for j in range(n_cols))
        for row in cell_data
    )
    LINE_H  = FONT_SIZE_TABLE * 0.0013   # empirical height per line in axes units
    PADDING = 0.012                       # top/bottom padding within each cell

    header_height = LINE_H * max_header_lines + PADDING
    data_height   = LINE_H * max_data_lines   + PADDING
    # Enforce minimum heights to prevent overly compressed rows
    header_height = max(header_height, 0.045)
    data_height   = max(data_height,   0.038)

    table = ax.table(cellText=cell_data, colLabels=col_labels,
                     cellLoc="center", loc="center",
                     colWidths=col_widths_norm,
                     bbox=[0, 0, 1, 1])
    table.auto_set_font_size(False)
    table.set_fontsize(FONT_SIZE_TABLE)

    # Apply calculated row heights
    for (row, col), cell in table.get_celld().items():
        if row == 0:
            cell.set_height(header_height)
        else:
            cell.set_height(data_height)

    # Style header row
    for j in range(n_cols):
        cell = table[0, j]
        cell.set_facecolor("#f0f0f0")
        cell.set_text_props(fontweight="bold", color="black",
                            verticalalignment="center")
        cell.set_edgecolor("#aaaaaa")
        cell.set_linewidth(1.2)

    # Style data rows with alternating background
    for i in range(1, n_rows + 1):
        bg = "#ffffff" if i % 2 == 1 else "#f9f9f9"
        for j in range(n_cols):
            cell = table[i, j]
            cell.set_facecolor(bg)
            cell.set_edgecolor("#cccccc")
            cell.set_linewidth(0.8)
            cell.set_text_props(color="black", verticalalignment="center")

    return table


#7. Load and align time points
